# Frontend environment variables
# Copy this file to .env.local and fill in real values
# NEVER commit .env.local to git

# URL of the backend FastAPI server — used by Next.js rewrite at runtime (server-side only)
# Dev: http://localhost:8000  (run `uvicorn api:app --reload` in repo root)
# Docker local: leave unset — Dockerfile defaults to http://backend:8000
BACKEND_URL=http://localhost:8000

# Supabase — get from supabase.com > project > Settings > API
# Use the anon/public key here (NOT the service_role key)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...  # anon key (safe to expose in browser)
