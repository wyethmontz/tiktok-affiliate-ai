# Backend environment variables
# Copy this file to .env and fill in real values
# NEVER commit .env to git

# Claude (Anthropic)
ANTHROPIC_API_KEY=sk-ant-...

# Supabase — get from supabase.com > project > Settings > API
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_KEY=eyJ...  # service_role key (kept server-side only)

# Replicate — get from replicate.com/account/api-tokens
REPLICATE_API_TOKEN=r8_...

# ElevenLabs — get from elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=sk_...

# Hugging Face — get from huggingface.co/settings/tokens
HF_TOKEN=hf_...

# CORS — comma-separated list of allowed frontend origins
# Dev: http://localhost:3000
# Prod: add your Cloudflare tunnel URL here
ALLOWED_ORIGINS=http://localhost:3000,https://<your-tunnel>.trycloudflare.com
